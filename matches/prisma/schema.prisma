generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum InteractionType {
  LIKE
  DISLIKE
  SUPERLIKE
  REPORT
}

model Interaction {
  id        Int             @id @default(autoincrement())
  type      InteractionType
  fromId    Int
  toId      Int
  createdAt DateTime        @default(now())

  @@unique([fromId, toId])
}

model Match {
  id        Int      @id @default(autoincrement())
  user1Id   Int
  user2Id   Int
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
}
