{
  "info": {
    "name": "Tindel API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@example.com\",\"password\":\"password123\",\"name\":\"Test User\",\"age\":25}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@example.com\",\"password\":\"password123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile (me)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"new@example.com\",\"password\":\"password\",\"name\":\"New User\",\"age\":20}"
            }
          }
        },
        {
          "name": "Update User (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Updated Name\"}"
            }
          }
        },
        {
          "name": "Update User (PUT)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Updated Name PUT\"}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Interactions",
      "item": [
        {
          "name": "Get All Interactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/interactions"
          }
        },
        {
          "name": "Get Interaction by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/interactions/1"
          }
        },
        {
          "name": "Get Interactions by User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/interactions/user/1"
          }
        },
        {
          "name": "Create Interaction",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/interactions",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"type\":\"LIKE\",\"fromId\":1,\"toId\":2}"
            }
          }
        },
        {
          "name": "Update Interaction (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/interactions/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"type\":\"SUPERLIKE\"}"
            }
          }
        },
        {
          "name": "Delete Interaction",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/interactions/1"
          }
        }
      ]
    },
    {
      "name": "Matches",
      "item": [
        {
          "name": "Get All Matches",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/matches",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Get Match by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/matches/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Get Matches by User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/matches/user/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Create Match",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/matches",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"user1Id\":1,\"user2Id\":2}"
            }
          }
        },
        {
          "name": "Delete Match",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/matches/1",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Get All Messages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/messages"
          }
        },
        {
          "name": "Get Messages by Chat",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/messages/chat/1"
          }
        },
        {
          "name": "Create Message",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/messages",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"content\":\"Hello!\",\"fromId\":1,\"chatId\":1}"
            }
          }
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/messages/1"
          }
        }
      ]
    },
    {
      "name": "Photos",
      "item": [
        {
          "name": "Get All Photos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/photos"
          }
        },
        {
          "name": "Get Photos by User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/photos/user/1"
          }
        },
        {
          "name": "Create Photo",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/photos",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"url\":\"http://example.com/photo.jpg\",\"isPrimary\":true,\"userId\":1}"
            }
          }
        },
        {
          "name": "Delete Photo",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/photos/1"
          }
        }
      ]
    },
    {
      "name": "Chats",
      "item": [
        {
          "name": "Get All Chats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats"
          }
        },
        {
          "name": "Create Chat",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"matchId\":1}"
            }
          }
        },
        {
          "name": "Delete Chat",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/chats/1"
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get All Subscriptions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/subscriptions"
          }
        },
        {
          "name": "Get Subscription by Tier",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/subscriptions/PREMIUM"
          }
        },
        {
          "name": "Create Subscription",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/subscriptions",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"tier\":\"PREMIUM\",\"name\":\"Premium Plan\",\"description\":\"Best plan\",\"price\":9.99,\"features\":[\"Unlimited likes\"]}"
            }
          }
        },
        {
          "name": "Delete Subscription",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/subscriptions/PREMIUM"
          }
        }
      ]
    }
  ]
}